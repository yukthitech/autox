<examples xmlns:s="/fw/ccg/XMLBeanParser">
	<s:exprPattern enabled="false"/>

	<collection name="com.yukthitech.autox.test.ui.steps.ClickAndDownloadStep">
		<example>
			<description>Clicks a link in ui to download file</description>
			
			<content><![CDATA[
				<s:ui-click-and-download locator="id: downloadLink" pathName="filePath"/>
			]]></content>
		</example>
	</collection>

	<collection name="com.yukthitech.autox.test.ui.steps.ClickStep">
		<example>
			<description>Click the element using locator</description>
			
			<content><![CDATA[
				<s:ui-click locator="id: button"/>
			]]></content>
		</example>
	</collection>

	<collection name="com.yukthitech.autox.test.ui.steps.CloseWindowStep">
		<example>
			<description>Click the element using locator</description>
			
			<content><![CDATA[
				<s:ui-open-window url="/index.html" name="Index"/>
				<s:ui-switch-window locator="Index"/>
				<s:ui-is-visible locator="id: button" name="visibFlag1"/>
				<s:ui-close-window />
			]]></content>
		</example>
	</collection>

	<collection name="com.yukthitech.autox.test.ui.steps.FillFormStep">
		<example>
			<description>Filling html form using field locators and json data</description>
			
			<content><![CDATA[
				<s:ui-goto-page uri="/form.html" />

				<s:ui-fill-form locator="id:sampleForm">
					<data>
						{
							"name": "kranthi",
							"id:genderDropDown": "male",
							"address": "line1\nline2",
							"color": ["red", "green", "blue"],
							"c:srchDropDown:vehicle": "Boat",
							"c:srchDropDown:ranking": "Nine"
						}
					</data>
				</s:ui-fill-form>

				<s:ui-assert-value locator="xpath: //input[@name='name']" value="kranthi"/>
			]]></content>
		</example>
	</collection>

	<collection name="com.yukthitech.autox.test.ui.steps.GotoPageStep">
		<example>
			<description>Filling html form</description>
			
			<content><![CDATA[
				<s:ui-goto-page uri="/index.html" />
			]]></content>
		</example>
	</collection>

	<collection name="com.yukthitech.autox.test.ui.steps.HandleAlertStep">
		<example>
			<description>Validating and accepting alert prompt</description>
			
			<content><![CDATA[
				<s:ui-click locator="id: alertBut"/>
				<s:sleep time="100"/>

				<s:ui-handle-alert expectedMessage="Test Alert Message!!!"/>
			]]></content>
		</example>
	</collection>

	<collection name="com.yukthitech.autox.test.ui.steps.HandleConfirmStep">
		<example>
			<description>Validating and accepting confirm prompt</description>
			
			<content><![CDATA[
				<s:ui-click locator="id: confirmBut"/>
				<s:sleep time="100"/>

				<s:ui-handle-confirm expectedMessage="Choose your button..." accept="true"/>
			]]></content>
		</example>
	</collection>

	<collection name="com.yukthitech.autox.test.ui.steps.HandlePromptStep">
		<example>
			<description>Validating and feeding text into prompt</description>
			
			<content><![CDATA[
				<s:ui-click locator="id: promptBut"/>
				<s:sleep time="100"/>

				<s:ui-handle-prompt expectedMessage="Provide a value..." accept="true" text="Kranthi"/>
			]]></content>
		</example>
	</collection>

	<collection name="com.yukthitech.autox.test.ui.steps.IsVisibleStep">
		<example>
			<description>Checking for visibility of element</description>
			
			<content><![CDATA[
				<s:ui-is-visible locator="id: testLayer" name="visibFlag1"/>
			]]></content>
		</example>
	</collection>

	<collection name="com.yukthitech.autox.test.ui.steps.LogScreenShotStep">
		<example>
			<description>Taking screen shot of the screen</description>
			
			<content><![CDATA[
				<s:ui-log-screen-shot name="test.png" />
			]]></content>
		</example>
	</collection>

	<collection name="com.yukthitech.autox.test.ui.steps.OpenWindowStep">
		<example>
			<description>Opening a new window</description>
			
			<content><![CDATA[
				<s:ui-open-window url="/index.html" name="Index"/>
				<s:ui-switch-window locator="Index"/>
				<s:ui-is-visible locator="id: button" name="visibFlag1"/>
				<s:ui-close-window />
			]]></content>
		</example>
	</collection>

	<collection name="com.yukthitech.autox.test.ui.steps.RecordVideoStep">
		<example>
			<description>Recording video of ui steps execution</description>
			
			<content><![CDATA[
				<s:record-video name="form-filling">
					<s:ui-goto-page uri="/form.html" />

					<s:ui-fill-form locator="id:sampleForm">
						<data>
							{
								"name": "kranthi",
								"id:genderDropDown": "male",
								"address": "line1\nline2",
								"color": ["red", "green", "blue"]
							}
						</data>
					</s:ui-fill-form>

					<s:ui-assert-value locator="xpath: //input[@name='name']" value="kranthi"/>
				</s:record-video>
			]]></content>
		</example>
	</collection>

	<collection name="com.yukthitech.autox.test.ui.steps.SwitchWindow">
		<example>
			<description>Switching between browser windows</description>
			
			<content><![CDATA[
				<s:ui-open-window url="/index.html" name="Index"/>
				<s:ui-switch-window locator="Index"/>
				<s:ui-is-visible locator="id: button" name="visibFlag1"/>

				<s:ui-switch-window />
				<s:ui-assert-visibility locator="id: downloadLink"/>
			]]></content>
		</example>
	</collection>

	<collection name="com.yukthitech.autox.test.ui.steps.UiGetElementsStep">
		<example>
			<description>Getting elements using locator</description>
			
			<content><![CDATA[
				<s:ui-get-elements locator="xpath: //input[@type='checkbox']" name="checkBoxes"/>

				<s:forEach expression="attr.checkBoxes" loopVar="cbox">
					<s:set expression="values" value="${attr.values},${uiElemAttr('value', attr.cbox, null)}"/>
				</s:forEach>
			]]></content>
		</example>
	</collection>

	<collection name="com.yukthitech.autox.test.ui.steps.UiGetValueStep">
		<example>
			<description>Getting value of specified locator</description>
			
			<content><![CDATA[
				<s:ui-get-value locator="xpath: //input[@name='statusFld']" name="fldValue"/>
			]]></content>
		</example>
	</collection>

	<collection name="com.yukthitech.autox.test.ui.steps.UiSetValueStep">
		<example>
			<description>Setting value of element with specified locator</description>
			
			<content><![CDATA[
				<s:ui-set-value locator="xpath: //input[@name='statusFld']" value="OPEN"/>
			]]></content>
		</example>
		<example>
			<description>Setting value using expression</description>
			
			<content><![CDATA[
				<s:set expression="fieldValue" value="OPEN"/>
				<s:ui-set-value locator="xpath: //input[@name='statusFld']" value="attr: fieldValue"/>
			]]></content>
		</example>
	</collection>

	<collection name="com.yukthitech.autox.test.ui.assertion.AssertVisibility">
		<example>
			<description>Asserts the visibility of ui element</description>
			
			<content><![CDATA[
				<s:ui-assert-visibility locator="id: downloadLink"/>
			]]></content>
		</example>
	</collection>

	<collection name="com.yukthitech.autox.test.ui.assertion.UiAssertValue">
		<example>
			<description>Asserts value of ui element</description>
			
			<content><![CDATA[
				<s:ui-assert-value locator="xpath: //input[@name='name']" value="kranthi"/>
			]]></content>
		</example>
	</collection>

	<collection name="com.yukthitech.autox.test.ui.steps.UiExecuteJsStep">
		<example>
			<description>Clicking an ui element using javascript</description>
			
			<content><![CDATA[
				<s:ui-execute-js>
					<script>
						document.getElementById("changeByJs").click()
					</script>
				</s:ui-execute-js>
			]]></content>
		</example>
	</collection>
</examples>
